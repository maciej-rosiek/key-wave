<Window x:Class="KeyWave.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sim="clr-namespace:KeyWave.Lighting.Simulator"
        Title="KeyWave"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        Width="680" Height="640"
        Background="#101014" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"
                   Text="KeyWave"/>
        <TextBlock DockPanel.Dock="Top" Opacity="0.7" Margin="0,0,0,12"
                   Text="Reactive keyboard lighting for LampArray devices."/>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Real devices:" Margin="0,0,8,4" Opacity="0.7"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DeviceCountText" Text="0"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Lamps:" Margin="0,0,8,4" Opacity="0.7"/>
            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="LampCountText" Text="—"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Last key:" Margin="0,0,8,4" Opacity="0.7"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LastKeyText" Text="—"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="Mode:" Margin="0,0,8,4" Opacity="0.7"/>
            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="ModeText" Text="simulator"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Theme:" Margin="0,0,8,4" Opacity="0.7"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ThemeText" Text="—"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="Effect:" Margin="0,0,8,4" Opacity="0.7"/>
            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="EffectText" Text="—"/>
        </Grid>

        <Border DockPanel.Dock="Top" Padding="10" CornerRadius="4" Background="#1A1A22"
                BorderBrush="#2A2A35" BorderThickness="1" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Text="Ripple settings"
                           Opacity="0.55" FontSize="11" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Distance" Opacity="0.7" VerticalAlignment="Center"/>
                <Slider x:Name="DistanceSlider" Grid.Row="1" Grid.Column="1" Margin="6,0,6,0"
                        Minimum="1" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="DistanceValue" Grid.Row="1" Grid.Column="2" TextAlignment="Right"
                           VerticalAlignment="Center" Opacity="0.85"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Width" Opacity="0.7" VerticalAlignment="Center"/>
                <Slider x:Name="WidthSlider" Grid.Row="2" Grid.Column="1" Margin="6,0,6,0"
                        Minimum="1" Maximum="4" TickFrequency="1" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="WidthValue" Grid.Row="2" Grid.Column="2" TextAlignment="Right"
                           VerticalAlignment="Center" Opacity="0.85"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Speed" Opacity="0.7" VerticalAlignment="Center"/>
                <Slider x:Name="SpeedSlider" Grid.Row="3" Grid.Column="1" Margin="6,0,6,0"
                        Minimum="10" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="SpeedValue" Grid.Row="3" Grid.Column="2" TextAlignment="Right"
                           VerticalAlignment="Center" Opacity="0.85"/>

                <CheckBox x:Name="WallBounceCheck" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                          Content="Wall bounce" Margin="0,8,0,0" Foreground="#E0E0E0"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="10" CornerRadius="4" Background="#1A1A22"
                BorderBrush="#2A2A35" BorderThickness="1" Margin="0,12,0,0">
            <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="11">
                The on-screen 24-zone grid mirrors what would be sent to a real LampArray.
                Keep this window focused — the LampArray API only applies colors when the app is in foreground,
                unless installed as a packaged app via the MSIX in Releases.
                Close to minimize to tray; right-click the tray icon to exit.
            </TextBlock>
        </Border>

        <sim:SimulatorPanel x:Name="Simulator"/>
    </DockPanel>
</Window>
